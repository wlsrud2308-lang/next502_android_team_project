<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="bitc.next502.flutter_server.mapper.MovieMapper">

    <insert id="insertMovie" parameterType="bitc.next502.flutter_server.dto.MovieDTO">
        INSERT INTO movie (
            title,
            release_date,
            movie_cd,
            `rank`,
            rank_inten,
            rnum,
            rank_old_and_new
        )
        VALUES (
                   #{movieNm},
                   #{openDt},
                   #{movieCd},
                   #{rank},
                   #{rankInten},
                   #{rnum},
                   #{rankOldAndNew}
               )
    </insert>

</mapper>