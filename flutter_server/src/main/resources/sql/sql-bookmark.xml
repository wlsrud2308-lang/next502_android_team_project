<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="bitc.next502.flutter_server.mapper.BookmarkMapper">

    <!-- 1. 북마크 존재 여부 확인 (Toggle 로직에서 사용) -->
    <select id="checkBookmark" parameterType="bitc.next502.flutter_server.dto.BookmarkDTO" resultType="int">
        SELECT COUNT(*)
        FROM bookmark
        WHERE user_num = #{userNum} AND movie_id = #{movieId}
    </select>

    <!-- 2. 북마크 추가 (Insert) -->
    <insert id="insertBookmark" parameterType="bitc.next502.flutter_server.dto.BookmarkDTO">
        INSERT INTO bookmark (user_num, movie_id, created_at)
        VALUES (#{userNum}, #{movieId}, NOW())
    </insert>

    <!-- 3. 북마크 삭제 (Delete) -->
    <delete id="deleteBookmark" parameterType="bitc.next502.flutter_server.dto.BookmarkDTO">
        DELETE FROM bookmark
        WHERE user_num = #{userNum} AND movie_id = #{movieId}
    </delete>

    <!-- 4. 특정 유저의 북마크한 모든 영화 ID 리스트 조회 -->
    <select id="getMovieIdsByUser" parameterType="int" resultType="int">
        SELECT movie_id
        FROM bookmark
        WHERE user_num = #{userNum}
    </select>

</mapper>