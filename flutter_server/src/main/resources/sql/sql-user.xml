<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="bitc.next502.flutter_server.mapper.UserMapper">
    <select id="findUserNumByUid" resultType="Integer">
        SELECT user_num
        FROM users
        WHERE uid = #{uid}
    </select>
</mapper>