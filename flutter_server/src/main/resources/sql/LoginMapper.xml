<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="bitc.next502.flutter_server.mapper.LoginMapper">

    <insert id="insertNormalUser" parameterType="bitc.next502.flutter_server.dto.UserDTO">
        INSERT INTO user (
            email,
            id,
            password,
            nickname,
        )
        VALUES (
            #{email},
            #{id},
            #{password},
            #{nickname},
        )
    </insert>

</mapper>